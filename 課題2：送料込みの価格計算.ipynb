     "text": [
      "送料として350円かかります\n",
      "送料込みの価格は2330円です。\n"
     ]
    }
   ],
   "source": [
    "price = int(input(\"税抜価格を入力してください: \"))\n",
    "\n",
    "price_with_tax = int(price * 1.1)\n",
    "\n",
    "if price_with_tax >= 2000:\n",
    "    shipping_cost = 0\n",
    "    print(\"送料は無料です\")\n",
    "else:\n",
    "    shipping_cost = 350\n",
    "    print(\"送料として350円かかります\")\n",
    "    price_with_tax += shipping_cost\n",
    "    \n",
    "print(f\"送料込みの価格は{price_with_tax}円です。\")"
   ]
  }
 ],
