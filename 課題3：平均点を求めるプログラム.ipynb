   "source": [
    "score = []\n",
    "\n",
    "while True:\n",
    "    score.append(int(input(\"点数を入力してください: \")))\n",
    "    \n",
    "    if score[-1] == -1:\n",
    "        score.pop()  # -1をリストから削除\n",
    "        break\n",
    "\n",
    "average = sum(score) / len(score) if score else 0\n",
    "print(f\"平均点は {average:.1f}点 です。\")"
   ]
  }
