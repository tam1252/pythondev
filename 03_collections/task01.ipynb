    "grades = [70, 75, 80, 85, 90]\n",
    "\n",
    "print(f\"平均点: {sum(grades) / len(grades)}\")\n",
    "print(f\"最高点: {max(grades)}\")\n",
    "print(f\"最低点: {min(grades)}\")\n",
    "print(f\"平均点以上の学生の数: {len([grade for grade in grades if grade >= sum(grades) / len(grades)])}\")"
   ]
  }
