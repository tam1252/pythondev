   "source": [
    "gankin = int(input(\"元金を入力してください: \"))\n",
    "nenritsu = float(input(\"年利(%)を入力してください）: \"))\n",
    "\n",
    "for i in range(10):\n",
    "    gankin += gankin * nenritsu / 100\n",
    "\n",
    "print(f\"10年後の金額は {gankin:.2f} 円になります。\")"
   ]
  }
