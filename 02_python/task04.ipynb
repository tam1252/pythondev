      "エラー: 整数を入力してください\n"
     ]
    }
   ],
   "source": [
    "try:\n",
    "    a = int(input(\"整数を入力してください: \"))\n",
    "    b = int(input(\"もう一つ整数を入力してください: \"))\n",
    "    result = a / b\n",
    "    print(f\"計算結果: {result}\")\n",
    "except ValueError:\n",
    "    print(\"エラー: 整数を入力してください\")\n",
    "except ZeroDivisionError:\n",
    "    print(\"エラー: 0 で割ることはできません\")"
   ]
  }
 ],
